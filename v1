<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>方便指數計算器 - 明愛粉嶺陳震夏中學</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>
    body { font-family: 'Microsoft JhengHei', system-ui, sans-serif; }
    th, td { padding: 12px 8px; text-align: center; vertical-align: middle; }
    .prob-th { font-size: 0.85rem; line-height: 1.3; min-width: 90px; }
    .draggable { cursor: move; }
    .dragging { opacity: 0.5; background-color: #f3f4f6; }
    .grade-name { cursor: text; }
  </style>
</head>
<body class="bg-gray-50 min-h-screen">

<div class="max-w-7xl mx-auto p-4 md:p-8">
  
  <!-- 頁首介紹 -->
  <div class="bg-white rounded-3xl shadow-lg p-8 mb-8 text-center">
    <h1 class="text-4xl font-bold text-gray-800 mb-3">
      明愛粉嶺陳震夏中學<br>方便指數計算器
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl mx-auto">
      幫助學校優化各年級課室位置，計算上落樓層期望值，找出最方便的全校配置方案。
    </p>
    
    <div class="mt-8 bg-gray-50 rounded-2xl p-6 max-w-4xl mx-auto">
      <h3 class="font-semibold text-lg mb-3 text-gray-700">計算公式</h3>
      <div class="formula bg-white p-5 rounded-xl border border-gray-200 text-left inline-block">
        <strong>上落層數期望值：</strong><br>
        <span class="text-lg font-medium">E = (P(操場) × |層差| + P(圖書館) × |層差| + P(教員室) × |層差|) × 2</span>
      </div>
    </div>
  </div>

  <!-- 自訂目的地 -->
  <div class="bg-white rounded-2xl shadow-lg p-6 mb-8">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-semibold flex items-center gap-2">
        <i class="fa-solid fa-location-dot"></i> 自訂目的地
      </h2>
      <button onclick="addDestination()" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-xl text-sm flex items-center gap-2">
        <i class="fa-solid fa-plus"></i> 新增目的地
      </button>
    </div>
    <div id="destinationsContainer" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"></div>
  </div>

  <!-- 年級表格 -->
  <div class="bg-white rounded-2xl shadow-lg p-6 mb-8">
    <div class="flex justify-between items-center mb-6">
      <h2 class="text-xl font-semibold flex items-center gap-2">
        <i class="fa-solid fa-users"></i> 年級設定
      </h2>
      <div class="flex gap-3">
        <button onclick="addGrade()" class="bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-xl font-medium flex items-center gap-2">
          <i class="fa-solid fa-plus"></i> 新增年級
        </button>
        <button onclick="resetToDefault()" 
                class="bg-gray-500 hover:bg-gray-600 text-white px-5 py-2.5 rounded-xl font-medium flex items-center gap-2">
          <i class="fa-solid fa-rotate-right"></i> 重置全部
        </button>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full min-w-[1400px]" id="gradeTable">
        <thead id="tableHead"></thead>
        <tbody id="gradeBody"></tbody>
      </table>
    </div>
  </div>

  <!-- 最佳化按鈕 -->
  <div class="bg-white rounded-2xl shadow-lg p-6 mb-8">
    <button onclick="showAllConfigurations()" 
            class="w-full bg-gradient-to-r from-purple-600 to-violet-600 text-white py-5 rounded-2xl font-semibold text-xl flex items-center justify-center gap-3 hover:brightness-110 transition">
      <i class="fa-solid fa-list-ol"></i> 顯示 Top 30 最佳全校配搭
    </button>
  </div>

  <!-- 總結 -->
  <div class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white rounded-3xl p-8 shadow-xl">
    <div class="flex flex-col md:flex-row justify-between items-center">
      <div>
        <p class="text-blue-100">全校加權平均方便指數</p>
        <div id="overallIndex" class="text-6xl font-bold">1.507</div>
      </div>
      <p class="text-sm opacity-75 mt-4 md:mt-0">數值越低越方便</p>
    </div>
  </div>
</div>

<!-- Modal -->
<div id="optModal" class="hidden fixed inset-0 bg-black/70 flex items-center justify-center z-50">
  <div class="bg-white rounded-3xl max-w-4xl w-full mx-4 max-h-[90vh] overflow-auto">
    <div class="p-8">
      <h2 class="text-2xl font-bold mb-6 flex items-center gap-3" id="modalTitle"></h2>
      <div id="optResults"></div>
      <button onclick="closeModal()" class="mt-6 w-full py-3 bg-gray-200 hover:bg-gray-300 rounded-2xl font-medium">關閉</button>
    </div>
  </div>
</div>

<script>
// 預設數據
const defaultDestinations = [
  { id: 1, name: "操場", floor: 0 },
  { id: 2, name: "圖書館", floor: 3 },
  { id: 3, name: "教員室", floor: 1 }
];

const defaultGrades = [
  { id: 1, name: "中一", floor: 2,   students: 136, probs: [0.2868, 0.0088, 0.0897] },
  { id: 2, name: "中二", floor: 4,   students: 166, probs: [0.2157, 0.0337, 0.1036] },
  { id: 3, name: "中三", floor: 5,   students: 168, probs: [0.1857, 0.0476, 0.0714] },
  { id: 4, name: "中四", floor: 2.5, students: 164, probs: [0.1476, 0.0293, 0.0378] },
  { id: 5, name: "中五", floor: 4.5, students: 145, probs: [0.1490, 0.0152, 0.0110] }
];

let destinations = JSON.parse(JSON.stringify(defaultDestinations));
let grades = JSON.parse(JSON.stringify(defaultGrades));

const colors = ['#ef4444', '#3b82f6', '#eab308', '#22c55e', '#f97316'];

function calculateExpectation(grade, floor = null) {
  const f = floor !== null ? floor : grade.floor;
  let total = 0;
  destinations.forEach((dest, i) => {
    total += (grade.probs[i] || 0) * Math.abs(f - dest.floor);
  });
  return total * 2;
}

function calculateSchoolAverage(assignment) {
  let totalWeighted = 0, totalStu = 0;
  grades.forEach(grade => {
    const fl = assignment ? assignment[grade.id] : grade.floor;
    totalWeighted += calculateExpectation(grade, fl) * grade.students;
    totalStu += grade.students;
  });
  return totalStu > 0 ? totalWeighted / totalStu : 0;
}

function resetToDefault() {
  if (confirm("確定要重置所有設定為初始值嗎？")) {
    destinations = JSON.parse(JSON.stringify(defaultDestinations));
    grades = JSON.parse(JSON.stringify(defaultGrades));
    renderDestinations();
    renderTable();
  }
}

function renderDestinations() {
  const container = document.getElementById('destinationsContainer');
  container.innerHTML = '';
  destinations.forEach((dest, index) => {
    const div = document.createElement('div');
    div.className = "border rounded-2xl p-4 bg-gray-50";
    div.innerHTML = `
      <div class="flex justify-between mb-3">
        <input type="text" value="${dest.name}" onchange="updateDestination(${index}, 'name', this.value)" class="font-medium bg-transparent border-b focus:border-blue-500 outline-none flex-1">
        <button onclick="deleteDestination(${index})" class="text-red-500 ml-3"><i class="fa-solid fa-trash"></i></button>
      </div>
      <input type="number" step="0.1" value="${dest.floor}" onchange="updateDestination(${index}, 'floor', this.value)" class="w-full border border-gray-300 rounded-lg px-4 py-3 text-center font-semibold">
    `;
    container.appendChild(div);
  });
}

function renderTable() {
  const thead = document.getElementById('tableHead');
  const tbody = document.getElementById('gradeBody');
  thead.innerHTML = '';
  tbody.innerHTML = '';

  let headerRow = `<tr class="bg-gray-100">`;
  headerRow += `<th class="py-4 px-4 text-left font-semibold">年級</th>`;
  headerRow += `<th class="py-4 px-4 text-center font-semibold">課室樓層</th>`;
  headerRow += `<th class="py-4 px-4 text-center font-semibold">總人數</th>`;

  destinations.forEach(dest => {
    headerRow += `<th class="prob-th py-4 px-3">${dest.name}</th>`;
  });

  headerRow += `<th class="py-4 px-6 text-center font-bold text-blue-700">期望值</th>`;
  headerRow += `<th class="py-4 px-4 w-12"></th></tr>`;
  thead.innerHTML = headerRow;

  grades.forEach((grade, gIndex) => {
    const E = calculateExpectation(grade);
    let probInputs = '';
    destinations.forEach((_, i) => {
      probInputs += `<td class="py-4 px-3 text-center">
        <input type="number" step="0.001" value="${(grade.probs[i]||0).toFixed(3)}" 
               onchange="updateProb(${gIndex}, ${i}, this.value)" 
               class="w-20 mx-auto block border border-gray-300 rounded-lg px-3 py-2 text-center text-sm">
      </td>`;
    });

    const row = document.createElement('tr');
    row.className = 'border-b hover:bg-gray-50 draggable';
    row.draggable = true;
    row.dataset.index = gIndex;
    row.innerHTML = `
      <td class="py-4 px-4 font-semibold" style="color: ${colors[gIndex % colors.length]}">
        <input type="text" value="${grade.name}" 
               onchange="updateGradeName(${gIndex}, this.value)" 
               class="grade-name bg-transparent border-b border-transparent hover:border-gray-300 focus:border-blue-500 outline-none text-center w-20">
      </td>
      <td class="py-4 px-4 text-center"><input type="number" step="0.1" value="${grade.floor}" onchange="updateGrade(${gIndex}, 'floor', this.value)" class="w-20 mx-auto block border border-gray-300 rounded-lg px-3 py-2 text-center"></td>
      <td class="py-4 px-4 text-center"><input type="number" value="${grade.students}" onchange="updateGrade(${gIndex}, 'students', this.value)" class="w-20 mx-auto block border border-gray-300 rounded-lg px-3 py-2 text-center"></td>
      ${probInputs}
      <td class="py-4 px-6 font-bold text-lg text-center" style="color: ${colors[gIndex % colors.length]}">${E.toFixed(3)}</td>
      <td class="py-4 px-4 text-center"><button onclick="deleteGrade(${gIndex})" class="text-red-500 hover:text-red-700"><i class="fa-solid fa-trash"></i></button></td>
    `;
    tbody.appendChild(row);

    row.addEventListener('dragstart', (e) => {
      e.dataTransfer.setData('text/plain', gIndex);
      row.classList.add('dragging');
    });
    row.addEventListener('dragend', () => row.classList.remove('dragging'));
    row.addEventListener('dragover', (e) => e.preventDefault());
    row.addEventListener('drop', (e) => {
      e.preventDefault();
      const fromIndex = parseInt(e.dataTransfer.getData('text/plain'));
      const toIndex = parseInt(row.dataset.index);
      if (fromIndex !== toIndex) {
        const [moved] = grades.splice(fromIndex, 1);
        grades.splice(toIndex, 0, moved);
        renderTable();
      }
    });
  });

  const avg = grades.reduce((sum, g) => sum + calculateExpectation(g) * g.students, 0) / (grades.reduce((sum, g) => sum + g.students, 0) || 1);
  document.getElementById('overallIndex').textContent = avg.toFixed(3);
}

function updateGradeName(index, newName) {
  grades[index].name = newName.trim() || `年級${index+1}`;
  renderTable();
}

function updateGrade(index, field, value) { 
  grades[index][field] = parseFloat(value) || 0; 
  renderTable(); 
}
function updateProb(gIndex, pIndex, value) { 
  grades[gIndex].probs[pIndex] = parseFloat(value) || 0; 
  renderTable(); 
}
function updateDestination(index, field, value) { 
  destinations[index][field] = field === 'floor' ? parseFloat(value) : value; 
  renderTable(); 
}

function addDestination() { 
  destinations.push({ id: Date.now(), name: "新目的地", floor: 3 }); 
  grades.forEach(grade => grade.probs.push(0)); 
  renderDestinations(); 
  renderTable(); 
}
function deleteDestination(index) { 
  if (destinations.length <= 1) return alert("至少保留一個目的地！"); 
  destinations.splice(index, 1); 
  grades.forEach(grade => grade.probs.splice(index, 1)); 
  renderDestinations(); 
  renderTable(); 
}
function addGrade() { 
  const newId = Math.max(...grades.map(g => g.id)) + 1; 
  const defaultProbs = destinations.map(() => 0.05); 
  grades.push({ id: newId, name: `中${newId}`, floor: 3, students: 150, probs: defaultProbs }); 
  renderTable(); 
}
function deleteGrade(index) { 
  if (grades.length > 1) { grades.splice(index, 1); renderTable(); } 
  else alert("至少保留一個年級！"); 
}

// 修正後的最佳化函數
function showAllConfigurations() {
  const modal = document.getElementById('optModal');
  const results = document.getElementById('optResults');
  const title = document.getElementById('modalTitle');

  title.textContent = "Top 30 最佳全校年級樓層配搭";

  let possibleFloors = [];
  for (let f = 0; f <= 8; f += 0.5) possibleFloors.push(f);

  let configurations = [];

  for (let attempt = 0; attempt < 2500; attempt++) {
    let selectedFloors = [...possibleFloors].sort(() => Math.random() - 0.5).slice(0, grades.length);
    let shuffledGrades = [...grades].sort(() => Math.random() - 0.5);
    let assignment = {};
    
    shuffledGrades.forEach((grade, i) => {
      assignment[grade.id] = selectedFloors[i];
    });

    const avg = calculateSchoolAverage(assignment);
    configurations.push({assignment, avg});
  }

  configurations.sort((a, b) => a.avg - b.avg);
  configurations = configurations.slice(0, 30);

  let html = `<p class="text-gray-600 mb-6">以下為前 30 種不同的最佳配置（全校加權平均指數由低到高）：</p>`;

  configurations.forEach((config, rank) => {
    const isBest = rank === 0;
    html += `
      <div class="border rounded-2xl p-5 mb-4 ${isBest ? 'bg-green-50 border-green-400' : 'bg-white'}">
        <div class="flex justify-between items-center mb-4">
          <span class="font-bold text-xl ${isBest ? 'text-green-600' : 'text-gray-700'}">第 ${rank+1} 名</span>
          <span class="font-mono text-2xl font-bold ${isBest ? 'text-green-600' : 'text-gray-700'}">${config.avg.toFixed(3)}</span>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-5 gap-x-6 gap-y-2 text-sm">`;
    
    grades.forEach(grade => {
      const sug = config.assignment[grade.id];
      html += `
        <div class="flex items-center gap-2">
          <span class="font-medium" style="color:${colors[grades.findIndex(g=>g.id===grade.id)%colors.length]}">${grade.name}</span>
          <span class="text-gray-500">→</span>
          <span class="font-semibold">${sug}樓</span>
        </div>`;
    });

    html += `</div></div>`;
  });

  results.innerHTML = html;
  modal.classList.remove('hidden');
}

function closeModal() {
  document.getElementById('optModal').classList.add('hidden');
}

// 初始化
window.onload = () => {
  renderDestinations();
  renderTable();
};
</script>

</body>
</html>
